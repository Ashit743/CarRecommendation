{
  "name": "@car-app/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "db:migrate": "drizzle-kit generate && tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@car-app/shared": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "^5.0.3",
    "@google/generative-ai": "^0.24.1",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}
