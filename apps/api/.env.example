# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://car_app:car_app@localhost:5432/car_app

# Google Gemini API key for recommendations narration
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Google Gemini model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Server port (default: 3000)
PORT=3000
