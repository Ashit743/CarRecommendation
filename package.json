{
  "name": "car-recommendation",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @car-app/api --filter @car-app/web dev",
    "build": "corepack pnpm -r build",
    "check": "corepack pnpm -r typecheck && corepack pnpm -r lint",
    "setup": "corepack pnpm install && corepack pnpm db:migrate && corepack pnpm db:seed",
    "db:migrate": "corepack pnpm --filter @car-app/api db:migrate",
    "db:seed": "corepack pnpm --filter @car-app/api db:seed",
    "db:reset": "corepack pnpm --filter @car-app/api db:reset",
    "db:studio": "corepack pnpm --filter @car-app/api db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.13.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
